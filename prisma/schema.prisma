// 故래소 데이터 모델 (spec.md 기준)
//
// 핵심: Clause 가 "자연어 문구(displayText)"와 "실행 룰(ruleType+params)"을 둘 다 들고,
//       Trade 가 매수~매도를 하나로 묶는 단위. 거래 종료 시 Report(사망/생존) 발급 →
//       ClauseSuggestion 으로 유언장 조항 제안.
//
// 보안: 증권사/거래소 API Key 는 서버 DB 에 저장하지 않는다(spec.md).
//       클라이언트 localStorage 보관 → 요청 시 Authorization 헤더로 전달 → 서버는 중계만.
//       그래서 BrokerAccount 같은 키 저장 모델은 없다.
//
// 담당: 스키마 owner P1(공유 필수) · Clause/룰 P4 · Report/제안 P3

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ──────────────────────────────────────────────────

enum Market {
  COIN // 암호화폐 (Upbit)
  KR // 한국주식 (KIS)
  US // 해외주식 (KIS 해외)
}

enum Side {
  BUY
  SELL
}

enum OrderType {
  LIMIT // 지정가
  MARKET // 시장가
}

enum TradeStatus {
  OPEN // 보유 중
  CLOSED // 청산 완료 → 보고서 트리거
}

enum OrderStatus {
  PENDING // 접수
  FILLED // 체결
  CANCELLED // 취소
}

enum ReportKind {
  DEATH // 사망진단서 (손실)
  SURVIVAL // 생존보고서 (수익)
}

enum SuggestionStatus {
  PENDING // 미결
  APPROVED // 승인 → 조항 반영
  REJECTED // 버림
}

// 주문 전 검사 룰 종류 (spec.md 위험 조건 매핑). MVP 는 P4 가 2개부터: CHASE_SURGE, NO_STOP_LOSS.
enum RuleType {
  // ── 인트로용 (첫 유언장 작성 시) ──────────────────────────
  CHASE_SURGE // 급등 후 추격 매수 (params: { window, pct })
  NO_STOP_LOSS // 손절 기준 없음
  ALL_IN // 전액 일괄 매수 (params: { maxPct })
  REVENGE_TRADE // 손실 만회 재진입
  MARKET_ORDER_IMPULSE // 과열 구간 시장가 충동 매수

  // ── 옵티마이징용 (거래 쌓이면서 보고서 기반 추가) ────────
  PREMARKET_GAP // 프리마켓 갭상 매수 (params: { pct })
  REPEATED_VIEWING // 반복 조회 후 충동 주문 (params: { count })
  PROFIT_TAKING // 목표가 도달해도 못 파는 패턴 (params: { targetPct })
  OVERTRADING // 하루 거래 횟수 초과 (params: { maxPerDay })
  NEWS_IMPULSE // 뉴스/커뮤니티 보자마자 주문
  AVERAGING_DOWN // 손실 중 물타기
  POSITION_SIZING // 종목별 비중 기준 없음 (params: { maxPct })
}

// ─── Models ─────────────────────────────────────────────────

// 사용자. MVP 자체 보관(추후 Supabase auth.users.id 매핑 가능). 증권사 키는 저장하지 않음.
model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  trades  Trade[]
  clauses Clause[]
}

// 거래 단위: 매수~매도를 하나로 묶음.  [owner: P1]
// 코인은 소수 수량/가격을 쓰므로 Decimal(20,8).
model Trade {
  id              String      @id @default(uuid())
  userId          String
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  market          Market
  symbol          String // 종목/티커 (예: "005930", "BTC", "AAPL")
  status          TradeStatus @default(OPEN)
  entryPrice      Decimal?    @db.Decimal(20, 8)
  entryQty        Decimal?    @db.Decimal(20, 8)
  entryAt         DateTime?
  exitPrice       Decimal?    @db.Decimal(20, 8)
  exitQty         Decimal?    @db.Decimal(20, 8)
  exitAt          DateTime?
  pnlPct          Float? // 손익률(%). 청산 시 계산 → 양수 SURVIVAL, 음수 DEATH
  holdDurationMin Int? // 보유 시간(분)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  orders         Order[]
  report         Report?
  derivedClauses Clause[] @relation("ClauseSource")

  @@index([userId])
}

// 개별 주문. 강행 사유(forceReason)·precheck 위반 스냅샷(willViolations) 기록.  [owner: P1]
model Order {
  id            String      @id @default(uuid())
  tradeId       String
  trade         Trade       @relation(fields: [tradeId], references: [id], onDelete: Cascade)
  side          Side
  orderType     OrderType   @default(LIMIT)
  price         Decimal?    @db.Decimal(20, 8) // 지정가일 때
  quantity      Decimal     @db.Decimal(20, 8)
  stopPrice     Decimal?    @db.Decimal(20, 8) // 손절 기준 (NO_STOP_LOSS 룰의 핵심)
  thesis        String? // 매수 이유
  forceReason   String? // 유언장 위반을 강행한 사유
  willViolations Json? // precheck 위반 스냅샷
  brokerOrderId String? // 증권사/거래소 주문 번호
  status        OrderStatus @default(PENDING)
  executedAt    DateTime?
  createdAt     DateTime    @default(now())

  @@index([tradeId])
}

// 투자 유언 조항: 룰 + 자연어 문구.  [owner: P4]
model Clause {
  id             String   @id @default(uuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  ruleType       RuleType
  params         Json // 룰 파라미터 (예: { "window": "1h", "pct": 15 })
  displayText    String // 낭독용 자연어 문구
  active         Boolean  @default(true)
  violationCount Int      @default(0) // 누적 위반 횟수
  sourceTradeId  String? // 이 조항을 낳은 거래(보고서 제안). null 이면 직접 작성.
  sourceTrade    Trade?   @relation("ClauseSource", fields: [sourceTradeId], references: [id])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  suggestions ClauseSuggestion[]

  @@index([userId])
}

// 거래 종료 시 Gemini 가 발급하는 사망진단서/생존보고서.  [owner: P3]
model Report {
  id              String     @id @default(uuid())
  tradeId         String     @unique
  trade           Trade      @relation(fields: [tradeId], references: [id], onDelete: Cascade)
  kind            ReportKind
  body            String? // 렌더용 서술 본문
  causes          Json? // 주요 사망/생존 원인 목록
  violatedClauses Json? // 위반(또는 지킨) 조항 스냅샷
  rawAiResponse   String? // Gemini 원본 응답(파싱 실패 대비 보관)
  createdAt       DateTime   @default(now())

  suggestions ClauseSuggestion[]
}

// 보고서가 제안한 새 조항. 승인 시 Clause 에 반영.  [owner: P3 생성 · P4 적용]
model ClauseSuggestion {
  id              String           @id @default(uuid())
  reportId        String
  report          Report           @relation(fields: [reportId], references: [id], onDelete: Cascade)
  clauseId        String? // 기존 조항 수정 제안이면 연결
  clause          Clause?          @relation(fields: [clauseId], references: [id])
  ruleType        RuleType
  suggestedParams Json // 제안 파라미터 (자유텍스트 금지 — 룰+params만)
  displayText     String // 제안 문구
  rationale       String? // 제안 근거
  status          SuggestionStatus @default(PENDING)
  createdAt       DateTime         @default(now())

  @@index([reportId])
}
