# ============================================================
# 故래소 환경 변수 예시 (서버 전용)
# 사용법: 이 파일을 복사해 .env 로 만들고 값을 채우세요.
#   cp .env.example .env
# .env 는 .gitignore 에 의해 커밋되지 않습니다.
#
# ⚠️ 보안(spec.md): 증권사/거래소 API Key(KIS·Upbit)는 여기(서버 env)에 두지
#    않습니다. 클라이언트 localStorage 에 보관 → 요청 시 Authorization 헤더로
#    전달 → 서버는 중계만. 따라서 아래에 KIS_APP_KEY 등은 없습니다.
# ============================================================

# --- Database (Supabase Postgres) ---------------------------
# Supabase 콘솔 > Project Settings > Database > Connection string
# 앱 런타임용: pooled 연결 (PgBouncer, 보통 6543 포트)
DATABASE_URL="postgresql://postgres:PASSWORD@HOST:6543/postgres?pgbouncer=true"
# 마이그레이션용: direct 연결 (non-pooled, 보통 5432 포트)
DIRECT_URL="postgresql://postgres:PASSWORD@HOST:5432/postgres"

# --- Broker provider 선택 -----------------------------------
# 개발 기본값 "mock" — 키 없이 Mock broker 로 전 구간 동작.
BROKER_PROVIDER="mock"            # "mock" | "kis"

# --- LLM (Google Gemini, 서버측 호출) -----------------------
# https://aistudio.google.com/apikey
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.5-flash"

# --- App ----------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ============================================================
# 데이터 파이프라인 (pipelines/, Python) — 과거 데이터 수집용 (앱과 별개)
#   가격: 미국 yfinance / 국내 KRX(pykrx) / 코인 Upbit → 키 불필요
#   아래는 뉴스·매크로·공시 수집에 필요한 무료 키들
# ============================================================
# 미국 뉴스(Alpaca) — https://alpaca.markets
ALPACA_API_KEY_ID=
ALPACA_API_SECRET_KEY=
# 미국 매크로(FRED) — https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=
# 미국 SEC — 키 불필요, 연락처 이메일만
SEC_USER_AGENT=SKYSH research <your_email@example.com>
# 국내 공시/재무(DART) — https://opendart.fss.or.kr
DART_API_KEY=
# 국내 매크로(한국은행 ECOS) — https://ecos.bok.or.kr/api
ECOS_API_KEY=
# (선택) 국내 가격을 KIS 실시간으로 받을 때만 — `--source kis`
# KIS_APP_KEY=
# KIS_APP_SECRET=
# KIS_ENV=prod
# 수집 시작일 / SEC raw facts 저장 여부
SKYSH_PRICES_START=2024-06-01
SKYSH_NEWS_START=2024-06-01
SKYSH_MACRO_START=2024-06-01
SKYSH_SEC_KEEP_FACTS=true
